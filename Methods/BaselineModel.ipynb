    "print(\"----- Duplicate Rows -----\")\n",
    "print(\"Exact duplicate full rows:\", raw_df.duplicated().sum())\n",
    "\n",
    "feature_only_raw = raw_df.drop(columns=[\"is_cancer\"])\n",
    "print(\"Duplicate feature rows:\", feature_only_raw.duplicated().sum())\n",
    "target_col = \"is_cancer\"\n",
    "# Find columns that look like peptide sequence columns\n",
    "amino_acids = set(\"ACDEFGHIKLMNPQRSTVWY\")\n",
    "\n",
    "sequence_candidates = []\n",
    "\n",
    "for col in raw_df.select_dtypes(include=[\"object\"]).columns:\n",
    "    values = raw_df[col].dropna().astype(str).str.upper()\n",
    "    \n",
    "    if len(values) == 0:\n",
    "        continue\n",
    "    \n",
    "    fraction_valid = values.apply(\n",
    "        lambda seq: len(seq) > 0 and set(seq).issubset(amino_acids)\n",
    "    ).mean()\n",
    "    \n",
    "    median_length = values.str.len().median()\n",
    "    \n",
