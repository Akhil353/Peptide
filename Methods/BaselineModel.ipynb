   "source": [
    "from sklearn.metrics import (\n",
    "    confusion_matrix,\n",
    "    classification_report,\n",
    "    roc_auc_score,\n",
    "    balanced_accuracy_score,\n",
    "    ConfusionMatrixDisplay\n",
    ")\n",
    "\n",
    "train_acc = accuracy_score(y_train, train_preds)\n",
    "test_acc = accuracy_score(y_test, preds)\n",
    "\n",
    "print(\"----- Exact Performance -----\")\n",
    "print(f\"Train Accuracy: {train_acc:.8f} ({train_acc:.4%})\")\n",
    "print(f\"Test Accuracy:  {test_acc:.8f} ({test_acc:.4%})\")\n",
    "print(f\"Train Errors:   {(train_preds != y_train).sum()} out of {len(y_train)}\")\n",
    "print(f\"Test Errors:    {(preds != y_test).sum()} out of {len(y_test)}\")\n",
    "\n",
    "print(\"\\n----- Class Balance -----\")\n",
    "print(\"Full dataset:\")\n",
    "print(y.value_counts())\n",
    "print(y.value_counts(normalize=True).rename(\"proportion\"))\n",
    "\n",
    "print(\"\\nTest dataset:\")\n",
    "print(y_test.value_counts())\n",
    "print(y_test.value_counts(normalize=True).rename(\"proportion\"))\n",
    "\n",
    "print(\"\\n----- More Reliable Metrics -----\")\n",
    "print(f\"Balanced Accuracy: {balanced_accuracy_score(y_test, preds):.8f}\")\n",
    "\n",
    "if len(np.unique(y_test)) == 2:\n",
    "    test_probs = model.predict_proba(X_test)[:, 1]\n",
    "    print(f\"ROC AUC:           {roc_auc_score(y_test, test_probs):.8f}\")\n",
    "\n",
    "print(\"\\n----- Classification Report -----\")\n",
    "print(classification_report(y_test, preds, digits=6))\n",
    "\n",
    "cm = confusion_matrix(y_test, preds)\n",
    "print(\"\\nConfusion Matrix:\")\n",
    "print(cm)\n",
    "\n",
    "ConfusionMatrixDisplay(confusion_matrix=cm).plot()\n",
    "plt.title(\"Random Forest Confusion Matrix\")\n",
    "plt.show()"
   ]
  },
