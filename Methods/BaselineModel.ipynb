    "    print(\"No sequence column detected. Define sequence_col manually before running this cell.\")\n",
    "else:\n",
    "    sequence_col = sequence_candidates[0]\n",
    "    amino_acid_list = list(\"ACDEFGHIKLMNPQRSTVWY\")\n",
    "\n",
    "    def peptide_features(sequence):\n",
    "        sequence = str(sequence).upper()\n",
    "        counts = Counter(sequence)\n",
    "        length = len(sequence)\n",
    "\n",
    "        features = {\"peptide_length\": length}\n",
    "\n",
    "        for aa in amino_acid_list:\n",
    "            features[f\"count_{aa}\"] = counts.get(aa, 0)\n",
    "            features[f\"fraction_{aa}\"] = counts.get(aa, 0) / length if length > 0 else 0\n",
    "\n",
    "        return features\n",
    "\n",
    "    peptide_feature_df = raw_df[sequence_col].apply(peptide_features).apply(pd.Series)\n",
    "    y_bio = raw_df[target_col]\n",
    "\n",
    "    display(peptide_feature_df.head())\n",
    "    print(\"Biological baseline feature shape:\", peptide_feature_df.shape)\n",
    "\n",
    "    groups = raw_df[sequence_col].astype(str)\n",
    "\n",
    "    group_split = GroupShuffleSplit(n_splits=1, test_size=0.2, random_state=42)\n",
    "    train_idx, test_idx = next(group_split.split(peptide_feature_df, y_bio, groups=groups))\n",
    "\n",
    "    X_train_bio = peptide_feature_df.iloc[train_idx]\n",
    "    X_test_bio = peptide_feature_df.iloc[test_idx]\n",
    "    y_train_bio = y_bio.iloc[train_idx]\n",
    "    y_test_bio = y_bio.iloc[test_idx]\n",
    "\n",
    "    bio_model = RandomForestClassifier(\n",
    "        n_estimators=200,\n",
    "        max_depth=None,\n",
    "        min_samples_split=2,\n",
    "        random_state=42,\n",
    "        n_jobs=-1\n",
    "    )\n",
    "\n",
    "    bio_model.fit(X_train_bio, y_train_bio)\n",
    "    bio_preds = bio_model.predict(X_test_bio)\n",
    "\n",
    "    print(\"\\n----- Amino Acid Composition Baseline -----\")\n",
    "    print(f\"Accuracy:          {accuracy_score(y_test_bio, bio_preds):.6f}\")\n",
    "    print(f\"Balanced Accuracy: {balanced_accuracy_score(y_test_bio, bio_preds):.6f}\")\n",
    "    print(\"\\nConfusion Matrix:\")\n",
    "    print(confusion_matrix(y_test_bio, bio_preds))\n",
    "    print(\"\\nClassification Report:\")\n",
    "    print(classification_report(y_test_bio, bio_preds, digits=6))"
   ]
