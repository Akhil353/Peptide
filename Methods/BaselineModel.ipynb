    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.model_selection import train_test_split, GridSearchCV\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.preprocessing import OneHotEncoder\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.metrics import (\n",
    "    accuracy_score,\n",
    "    balanced_accuracy_score,\n",
    "    classification_report,\n",
    "    ConfusionMatrixDisplay\n",
    ")\n",
    "\n",
    "# ============================================================\n",
    "# 1. Load and clean dataset\n",
    "# ============================================================\n",
    "\n",
    "df = pd.read_csv(\n",
    "    \"C:/Users/Waheg/Peptides/Peptide/Data/ML_Ready/mhc_class_I.csv\"\n",
    ")\n",
    "\n",
    "# Remove spaces accidentally attached to column names\n",
    "df.columns = df.columns.str.strip()\n",
    "\n",
    "# Remove CSV index column if present\n",
    "df = df.drop(columns=[\"Unnamed: 0\"], errors=\"ignore\")\n",
    "\n",
    "print(\"Dataset shape:\", df.shape)\n",
    "print(\"\\nClass counts:\")\n",
    "print(df[\"is_cancer\"].value_counts())\n",
    "\n",
    "# Optional:\n",
    "# Set to False to test whether Tissue is affecting performance.\n",
    "USE_TISSUE = True\n",
    "\n",
    "if not USE_TISSUE:\n",
    "    df = df.drop(columns=[\"Tissue\"], errors=\"ignore\")\n",
    "\n",
    "# ============================================================\n",
    "# 2. Separate features and target\n",
    "# ============================================================\n",
    "\n",
    "X = df.drop(columns=[\"is_cancer\"])\n",
    "y = df[\"is_cancer\"].astype(int)\n",
    "\n",
    "categorical_columns = X.select_dtypes(include=[\"object\"]).columns.tolist()\n",
    "numeric_columns = X.select_dtypes(exclude=[\"object\"]).columns.tolist()\n",
    "\n",
    "print(\"\\nCategorical columns:\", categorical_columns)\n",
    "print(\"Number of numeric columns:\", len(numeric_columns))\n",
    "\n",
    "# ============================================================\n",
    "# 3. Proper encoding\n",
    "# ============================================================\n",
    "# Tissue is categorical, so use one-hot encoding instead of\n",
    "# assigning arbitrary numbers with LabelEncoder.\n",
    "\n",
    "preprocessor = ColumnTransformer(\n",
    "    transformers=[\n",
    "        (\n",
    "            \"categorical\",\n",
    "            OneHotEncoder(handle_unknown=\"ignore\"),\n",
    "            categorical_columns\n",
    "        ),\n",
    "        (\n",
    "            \"numeric\",\n",
    "            \"passthrough\",\n",
    "            numeric_columns\n",
    "        )\n",
    "    ]\n",
    ")\n",
    "\n",
    "# ============================================================\n",
    "# 4. Train/test split\n",
    "# ============================================================\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X,\n",
    "    y,\n",
    "    test_size=0.4,\n",
    "    random_state=42,\n",
    "    stratify=y\n",
    ")\n",
    "\n",
    "# ============================================================\n",
    "# 5. Random Forest pipeline\n",
    "# ============================================================\n",
    "\n",
    "pipeline = Pipeline(\n",
    "    steps=[\n",
    "        (\"preprocessor\", preprocessor),\n",
    "        (\n",
    "            \"model\",\n",
    "            RandomForestClassifier(\n",
    "                random_state=42,\n",
    "                n_jobs=-1,\n",
    "                class_weight=\"balanced\"\n",
    "            )\n",
    "        )\n",
    "    ]\n",
    ")\n",
    "\n",
    "# Do not tune only number of trees.\n",
    "# max_depth and min_samples_leaf are the parameters that help\n",
    "# control your train/test gap.\n",
    "\n",
    "param_grid = {\n",
    "    \"model__n_estimators\": [300, 500, 700],\n",
    "    \"model__max_depth\": [5, 8, 10, 12, 15],\n",
    "    \"model__min_samples_split\": [5, 10, 15, 20],\n",
    "    \"model__min_samples_leaf\": [2, 5, 10],\n",
    "    \"model__max_features\": [\"sqrt\"]\n",
    "}\n",
    "\n",
    "grid = GridSearchCV(\n",
    "    estimator=pipeline,\n",
    "    param_grid=param_grid,\n",
    "    cv=3,\n",
    "    scoring=\"balanced_accuracy\",\n",
    "    n_jobs=-1,\n",
    "    verbose=1\n",
    ")\n",
    "\n",
    "grid.fit(X_train, y_train)\n",
    "\n",
    "print(\"\\nBest parameters:\")\n",
    "print(grid.best_params_)\n",
    "\n",
    "best_model = grid.best_estimator_\n",
    "\n",
    "# ============================================================\n",
    "# 6. Evaluate best model\n",
    "# ============================================================\n",
    "\n",
    "train_predictions = best_model.predict(X_train)\n",
    "test_predictions = best_model.predict(X_test)\n",
    "\n",
    "train_accuracy = accuracy_score(y_train, train_predictions)\n",
    "test_accuracy = accuracy_score(y_test, test_predictions)\n",
    "balanced_test_accuracy = balanced_accuracy_score(y_test, test_predictions)\n",
    "\n",
    "print(f\"\\nTrain Accuracy:         {train_accuracy:.2%}\")\n",
    "print(f\"Test Accuracy:          {test_accuracy:.2%}\")\n",
    "print(f\"Balanced Test Accuracy: {balanced_test_accuracy:.2%}\")\n",
    "\n",
    "print(\"\\nClassification Report:\")\n",
    "print(classification_report(y_test, test_predictions))\n",
    "\n",
    "ConfusionMatrixDisplay.from_predictions(\n",
    "    y_test,\n",
    "    test_predictions,\n",
    "    cmap=\"Blues\"\n",
    ")\n",
    "plt.title(\"Random Forest Confusion Matrix\")\n",
    "plt.show()\n",
    "\n",
    "# ============================================================\n",
    "# 7. Accuracy versus number of trees\n",
    "# ============================================================\n",
    "# This now uses the best depth, split, leaf, and feature settings.\n",
    "# Your original graph did not do this.\n",
    "\n",
    "best_depth = grid.best_params_[\"model__max_depth\"]\n",
    "best_split = grid.best_params_[\"model__min_samples_split\"]\n",
    "best_leaf = grid.best_params_[\"model__min_samples_leaf\"]\n",
    "best_features = grid.best_params_[\"model__max_features\"]\n",
    "\n",
    "tree_range = [10, 25, 50, 100, 200, 300, 500, 700]\n",
    "\n",
    "train_scores = []\n",
    "test_scores = []\n",
    "\n",
    "for number_of_trees in tree_range:\n",
    "    test_pipeline = Pipeline(\n",
    "        steps=[\n",
    "            (\"preprocessor\", preprocessor),\n",
    "            (\n",
    "                \"model\",\n",
    "                RandomForestClassifier(\n",
    "                    n_estimators=number_of_trees,\n",
    "                    max_depth=best_depth,\n",
    "                    min_samples_split=best_split,\n",
    "                    min_samples_leaf=best_leaf,\n",
    "                    max_features=best_features,\n",
    "                    class_weight=\"balanced\",\n",
    "                    random_state=42,\n",
    "                    n_jobs=-1\n",
    "                )\n",
    "            )\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    test_pipeline.fit(X_train, y_train)\n",
    "\n",
    "    train_score = accuracy_score(\n",
    "        y_train,\n",
    "        test_pipeline.predict(X_train)\n",
    "    )\n",
    "\n",
    "    test_score = accuracy_score(\n",
    "        y_test,\n",
    "        test_pipeline.predict(X_test)\n",
    "    )\n",
    "\n",
    "    train_scores.append(train_score)\n",
    "    test_scores.append(test_score)\n",
    "\n",
    "plt.figure(figsize=(9, 5))\n",
    "plt.plot(tree_range, train_scores, marker=\"o\", label=\"Train Accuracy\")\n",
    "plt.plot(tree_range, test_scores, marker=\"o\", label=\"Test Accuracy\")\n",
    "plt.xlabel(\"Number of Trees\")\n",
    "plt.ylabel(\"Accuracy\")\n",
    "plt.title(\"Tuned Random Forest: Accuracy vs Number of Trees\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()\n",
    "\n",
    "# ============================================================\n",
    "# 8. More useful graph: accuracy versus maximum depth\n",
    "# ============================================================\n",
    "# Depth is much more important than adding more trees when\n",
    "# trying to reduce overfitting.\n",
    "\n",
    "depth_range = [2, 4, 6, 8, 10, 12, 15, 20, None]\n",
    "\n",
    "depth_train_scores = []\n",
    "depth_test_scores = []\n",
    "\n",
    "for depth in depth_range:\n",
    "    depth_pipeline = Pipeline(\n",
    "        steps=[\n",
    "            (\"preprocessor\", preprocessor),\n",
    "            (\n",
    "                \"model\",\n",
    "                RandomForestClassifier(\n",
    "                    n_estimators=500,\n",
    "                    max_depth=depth,\n",
    "                    min_samples_split=best_split,\n",
    "                    min_samples_leaf=best_leaf,\n",
    "                    max_features=best_features,\n",
    "                    class_weight=\"balanced\",\n",
    "                    random_state=42,\n",
    "                    n_jobs=-1\n",
    "                )\n",
    "            )\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    depth_pipeline.fit(X_train, y_train)\n",
    "\n",
    "    depth_train_scores.append(\n",
    "        accuracy_score(y_train, depth_pipeline.predict(X_train))\n",
    "    )\n",
    "\n",
    "    depth_test_scores.append(\n",
    "        accuracy_score(y_test, depth_pipeline.predict(X_test))\n",
    "    )\n",
    "\n",
    "depth_labels = [str(depth) for depth in depth_range]\n",
    "\n",
    "plt.figure(figsize=(9, 5))\n",
    "plt.plot(depth_labels, depth_train_scores, marker=\"o\", label=\"Train Accuracy\")\n",
    "plt.plot(depth_labels, depth_test_scores, marker=\"o\", label=\"Test Accuracy\")\n",
    "plt.xlabel(\"Maximum Tree Depth\")\n",
    "plt.ylabel(\"Accuracy\")\n",
    "plt.title(\"Random Forest Accuracy vs Maximum Depth\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
